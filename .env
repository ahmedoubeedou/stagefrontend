# Base URL for the Laravel backend API
# If testing on a real device with Expo Go, change 127.0.0.1 to your computer's local IP address (e.g., 192.168.1.50)
# pour le travaille locale 
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000/api

# pour connecter dans mon telephone 
# EXPO_PUBLIC_API_URL=http://192.168.1.30:8000/api

